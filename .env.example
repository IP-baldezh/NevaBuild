# ==========================================================================
# NEVA BUILD — пример переменных окружения. Скопируйте в .env и заполните.
#   cp .env.example .env
# ==========================================================================

# --- Приложение ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- База данных (PostgreSQL) ---
# Локально:
DATABASE_URL=postgresql://neva:neva@localhost:5432/nevabuild?schema=public
# В docker-compose хост = имя сервиса "postgres":
# DATABASE_URL=postgresql://neva:neva@postgres:5432/nevabuild?schema=public

# --- Auth.js / NextAuth ---
# Сгенерируйте: openssl rand -base64 32
AUTH_SECRET=replace_with_openssl_rand_base64_32
AUTH_TRUST_HOST=true

# --- Seed: первичный администратор ---
ADMIN_EMAIL=admin@nevabuildexpo.ru
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Администратор

# --- Email (SMTP) для уведомлений и билетов ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="NEVA BUILD <info@neva-expo.ru>"
ORGANIZER_EMAIL=info@neva-expo.ru

# --- ЮKassa (приём платежей) ---
# TODO: получить значения в ЛК ЮKassa (https://yookassa.ru/) после модерации
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Куда вернуть пользователя после оплаты (заменится локалью автоматически в коде):
YOOKASSA_RETURN_URL=http://localhost:3000/ru/tickets/success
# Webhook настраивается в ЛК ЮKassa на: {NEXT_PUBLIC_SITE_URL}/api/payments/yookassa-webhook

# --- Объектное хранилище S3 (опционально) ---
# Если не заполнено — медиа сохраняется локально в /public/uploads (для dev)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-1

# --- Redis (опционально, кэш/rate-limit) ---
REDIS_URL=
